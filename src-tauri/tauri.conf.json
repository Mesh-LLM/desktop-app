{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mesh",
  "version": "0.1.0",
  "identifier": "cloud.meshllm.mesh-desktop",
  "build": {
    "frontendDist": "../ui/dist",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
