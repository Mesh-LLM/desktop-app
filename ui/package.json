{
  "name": "mesh-desktop-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test:e2e": "playwright test --project=mocked",
    "test:e2e:real": "playwright test --project=real",
    "lint": "eslint .",
    "format": "prettier --write src e2e *.ts *.js",
    "format:check": "prettier --check src e2e *.ts *.js"
  },
  "dependencies": {
    "lucide-react": "^1.22.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.3",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "8.1.0"
  }
}
